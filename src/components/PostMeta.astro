---
import { formatDate } from "../lib/posts";

interface Props {
  pubDate: Date;
  updatedDate?: Date;
  minutes?: number;
}

const { pubDate, updatedDate, minutes } = Astro.props;
---

<p class="post-meta">
  <span>{formatDate(pubDate)}</span>
  {minutes ? <span>{minutes} min read</span> : null}
  {updatedDate ? <span>updated {formatDate(updatedDate)}</span> : null}
</p>
