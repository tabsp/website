---
import config from "../config";

const comments = config.comments;
---

{
  comments.provider === "giscus" && (
    <section class="giscus-comments" aria-label="Comments">
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo={comments.giscus.repo}
        data-repo-id={comments.giscus.repoId}
        data-category={comments.giscus.category}
        data-category-id={comments.giscus.categoryId}
        data-mapping={comments.giscus.mapping}
        data-reactions-enabled={comments.giscus.reactionsEnabled ? "1" : "0"}
        data-emit-metadata={comments.giscus.emitMetadata ? "1" : "0"}
        data-input-position={comments.giscus.inputPosition}
        data-theme={comments.giscus.theme}
        data-lang={comments.giscus.lang}
        data-loading={comments.giscus.loading}
        async
      />
    </section>
  )
}
