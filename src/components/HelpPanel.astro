<aside class="help-panel" aria-label="Linewise keymap">
  <div class="help-panel-inner">
    <p class="eyebrow">:help linewise</p>
    <h2>Keys</h2>
    <dl>
      <div><dt>j / k</dt><dd>move selection</dd></div>
      <div><dt>Enter</dt><dd>open selected item</dd></div>
      <div><dt>gg / G</dt><dd>first or last item</dd></div>
      <div><dt>/</dt><dd>open search palette</dd></div>
      <div><dt>:</dt><dd>command mode</dd></div>
      <div><dt>b</dt><dd>buffer list</dd></div>
      <div><dt>q</dt><dd>quit current context</dd></div>
      <div><dt>Esc</dt><dd>normal mode</dd></div>
    </dl>
    <h2>Commands</h2>
    <dl>
      <div><dt>:posts</dt><dd>open the post buffer list</dd></div>
      <div><dt>:ls</dt><dd>open buffers</dd></div>
      <div><dt>/word</dt><dd>search posts and tags</dd></div>
      <div><dt>:search</dt><dd>open the picker</dd></div>
      <div><dt>:archive</dt><dd>open oldfiles</dd></div>
      <div><dt>:tags</dt><dd>open tag index</dd></div>
      <div><dt>:q</dt><dd>quit current context</dd></div>
    </dl>
  </div>
</aside>
