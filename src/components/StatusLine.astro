---
import { Github } from "lucide-astro";

interface Props {
  file?: string;
  mode?: string;
  meta?: string;
}

const { file = "index", mode = "NORMAL", meta = "static" } = Astro.props;
const repoUrl = "https://github.com/tabsp/linewise";
---

<footer class="status-line" aria-label="Page status">
  <span class="mode" data-status-mode>{mode}</span>
  <span class="file" data-status-file title={file}>{file}</span>
  <span class="spacer"></span>
  <span data-status-meta>{meta}</span>
  <a
    class="built-with"
    href={repoUrl}
    target="_blank"
    rel="noreferrer"
    aria-label="Built with Linewise, view on GitHub"
  >
    <Github aria-hidden="true" size={14} />
    <span class="built-with-text">Built with Linewise</span>
  </a>
</footer>
