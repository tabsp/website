---
import config from "../config";
import { getCollection } from "astro:content";
import { Hash, History, List, Search, Terminal } from "lucide-astro";
import { byNewest, isPublished } from "../lib/posts";

const posts = (await getCollection("blog")).filter(isPublished).sort(byNewest);
const tags = [...new Set(posts.flatMap(post => post.data.tags))].sort();
const searchIndex = [
  ...posts.map(post => ({
    type: "buffer",
    command: `/ ${post.data.title}`,
    title: post.data.title,
    description: post.data.description,
    href: `/posts/${post.id}/`,
    location: post.data.tags.join(", ") || "blog",
    keywords: [post.data.title, post.data.description, post.id, ...post.data.tags],
  })),
  ...tags.map(tag => ({
    type: "tag",
    command: `/ #${tag}`,
    title: `#${tag}`,
    description: `Jump to posts tagged ${tag}.`,
    href: `/tags/${tag}/`,
    location: ":tag",
    keywords: [tag, `#${tag}`],
  })),
];

const searchIndexJson = JSON.stringify(searchIndex).replaceAll("<", "\\u003c");

const navItems = [
  { label: "buffers", href: "/", icon: List },
  { label: "archive", href: "/archive/", icon: History },
  { label: "tags", href: "/tags/", icon: Hash },
  { label: "find", href: "/find/", icon: Search },
];
---

<nav class="command-bar" aria-label="Primary">
  <button
    type="button"
    class="palette-backdrop"
    data-close-palette
    aria-label="Close command palette"></button>
  <a class="leader" href="/" aria-label={`${config.site.title} home`}
    ><Terminal aria-hidden="true" size={16} /></a
  >
  <form class="command-input" data-command-form aria-label="Command line">
    <label class="prompt" for="linewise-command">:</label>
    <input
      id="linewise-command"
      data-command-input
      type="text"
      value=""
      autocomplete="off"
      spellcheck="false"
      aria-describedby="command-suggestions"
    />
    <span class="cursor" aria-hidden="true"></span>
    <div
      id="command-suggestions"
      class="command-suggestions"
      data-command-suggestions
      aria-label="Command suggestions"
    >
    </div>
  </form>
  <div class="commands">
    {
      navItems.map(item => {
        const Icon = item.icon;
        return (
          <a href={item.href} data-command={`:${item.label}`}>
            {Icon && <Icon aria-hidden="true" size={14} />}
            {item.label}
          </a>
        );
      })
    }
  </div>
  <script is:inline id="linewise-search-index" type="application/json" set:html={searchIndexJson} />
</nav>
