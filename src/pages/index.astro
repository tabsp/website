---
import { getCollection } from "astro:content";
import BufferList from "../components/BufferList.astro";
import SiteShell from "../components/SiteShell.astro";
import { byNewest, isPublished } from "../lib/posts";

const posts = (await getCollection("blog")).filter(isPublished).sort(byNewest);
---

<SiteShell file="buffers" status={`${posts.length} buffers`} routeType="list">
  <BufferList posts={posts} />
</SiteShell>
