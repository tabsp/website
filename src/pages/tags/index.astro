---
import { getCollection } from "astro:content";
import SiteShell from "../../components/SiteShell.astro";
import { collectTags, isPublished } from "../../lib/posts";

const posts = (await getCollection("blog")).filter(isPublished);
const tags = collectTags(posts);
---

<SiteShell title="Tags" file="tags" status={`${tags.length} tags`} routeType="list">
  <section class="tag-page">
    <header class="section-header">
      <p class="eyebrow">:tags</p>
      <h1>Tag stack</h1>
      <p>Topic marks for jumping across related buffers.</p>
    </header>

    <label class="list-filter picker-prompt">
      <span>/</span>
      <input type="search" placeholder="filter tags" autocomplete="off" data-list-filter />
    </label>

    <div class="tag-grid">
      {
        tags.map(({ tag, count }) => (
          <a
            href={`/tags/${tag}/`}
            class="tag-card"
            data-linewise-item
            data-linewise-title={`#${tag}`}
            data-filter-key={tag}
          >
            <span>#{tag}</span>
            <strong>{count}</strong>
          </a>
        ))
      }
    </div>
  </section>
</SiteShell>
