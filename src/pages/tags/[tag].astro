---
import { getCollection } from "astro:content";
import FindList from "../../components/FindList.astro";
import SiteShell from "../../components/SiteShell.astro";
import { byNewest, collectTags, formatDate, isPublished } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter(isPublished);
  return collectTags(posts).map(({ tag }) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const posts = (await getCollection("blog"))
  .filter(isPublished)
  .filter(post => post.data.tags.includes(tag ?? ""))
  .sort(byNewest);
---

<SiteShell
  title={`#${tag}`}
  file={`tag:${tag}`}
  status={`${posts.length} matches`}
  routeType="find"
>
  <FindList
    command={`:tag ${tag}`}
    title={`#${tag}`}
    items={posts.map(post => ({
      href: `/posts/${post.id}/`,
      title: post.data.title,
      excerpt: post.data.description,
      location: formatDate(post.data.pubDate),
    }))}
  />
</SiteShell>
