---
import SiteShell from "../components/SiteShell.astro";
---

<SiteShell title="Help" file="help" status="temporary" routeType="find">
  <section class="find-section help-buffer">
    <header class="section-header">
      <p class="eyebrow">:help linewise</p>
      <h1>Help</h1>
      <p>
        Linewise commands and motions. This is a temporary buffer, so it does not appear in the
        bufferline.
      </p>
    </header>

    <div class="help-grid">
      <section>
        <h2>Normal Mode</h2>
        <dl>
          <div><dt>j / k</dt><dd>move through rows</dd></div>
          <div><dt>Enter</dt><dd>open selected row</dd></div>
          <div><dt>gg / G</dt><dd>first or last row</dd></div>
          <div><dt>:</dt><dd>open command palette</dd></div>
          <div><dt>/</dt><dd>open search palette</dd></div>
          <div><dt>q</dt><dd>close current buffer or leave temporary buffer</dd></div>
          <div><dt>Esc</dt><dd>return to normal mode</dd></div>
        </dl>
      </section>

      <section>
        <h2>Commands</h2>
        <dl>
          <div><dt>:posts</dt><dd>open the post buffer list</dd></div>
          <div><dt>:ls</dt><dd>open buffers</dd></div>
          <div><dt>/word</dt><dd>search posts and tags</dd></div>
          <div><dt>:search</dt><dd>open find</dd></div>
          <div><dt>:archive</dt><dd>open oldfiles</dd></div>
          <div><dt>:tags</dt><dd>open tag index</dd></div>
          <div><dt>:help</dt><dd>open this temporary buffer</dd></div>
          <div><dt>:q</dt><dd>quit current context</dd></div>
        </dl>
      </section>
    </div>
  </section>
</SiteShell>
