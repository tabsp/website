---
import SiteShell from "../components/SiteShell.astro";
---

<SiteShell title="Search" file="find" status="client filter" routeType="find">
  <section class="search-panel">
    <header class="section-header">
      <p class="eyebrow">:find</p>
      <h1>Find buffers</h1>
      <p>
        Find posts and tags from one prompt. Move through results, then open the selected target.
      </p>
    </header>

    <label class="search-box picker-prompt">
      <span>/</span>
      <input id="search" type="search" placeholder="pattern" autocomplete="off" />
    </label>

    <ol id="results" class="find-list" aria-live="polite"></ol>
  </section>
</SiteShell>
