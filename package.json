{
  "name": "@tabsp/linewise",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "type": "module",
  "license": "MIT",
  "description": "Linewise is a Vim-inspired Astro starter for personal blogs.",
  "author": "tabsp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tabsp/linewise.git"
  },
  "homepage": "https://github.com/tabsp/linewise#readme",
  "bugs": {
    "url": "https://github.com/tabsp/linewise/issues"
  },
  "keywords": [
    "astro",
    "starter",
    "blog",
    "vim",
    "theme"
  ],
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "astro": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro",
    "check": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "upgrade:check": "node scripts/upgrade-check.mjs",
    "upgrade": "node scripts/upgrade.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:upgrade": "node scripts/test-upgrade.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.4",
    "lucide-astro": "^0.556.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/parser": "^8.60.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  }
}
